<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Waveguide-display palette: pure black renders as fully transparent on the
         glasses, so "surfaces" are black too — structure comes from outline strokes,
         never from filled panels (those glow as gray boxes on glass). -->
    <color name="background">#FF000000</color>
    <color name="surface">#FF000000</color>
    <color name="surface_variant">#FF000000</color>
    <color name="outline">#66FFFFFF</color>
    <!-- All accents sit on the Rokid system UI green hue (129°) so app and
         system HUD read as one color in recordings; semantics are carried by
         brightness instead: #41FF5F approve/primary, #33CC4B secondary/warning,
         #28A53D deny/error. -->
    <color name="primary">#FF41FF5F</color>
    <color name="primary_variant">#FF6FFF88</color>
    <color name="secondary">#FF33CC4B</color>
    <color name="on_background">#FFFFFFFF</color>
    <color name="on_surface">#FFE0E0E0</color>
    <color name="on_primary">#FF000000</color>
    <color name="error">#FF28A53D</color>
    <color name="approve_green">#FF41FF5F</color>
    <color name="deny_red">#FF28A53D</color>
    <color name="warning_amber">#FF33CC4B</color>
    <color name="transparent_overlay">#CC000000</color>
    <color name="scanner_border">#FF41FF5F</color>
</resources>
