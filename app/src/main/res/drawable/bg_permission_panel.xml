<?xml version="1.0" encoding="utf-8"?>
<!-- Pending-permission panel: black fill (transparent on glass, masks the transcript
     behind it for readability) with an amber outline instead of a filled surface. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/background" />
    <stroke android:width="1dp" android:color="@color/warning_amber" />
    <corners android:radius="10dp" />
</shape>
